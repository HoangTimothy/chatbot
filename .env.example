APP_ENV=local
APP_NAME=Enterprise RAG Platform

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rag
REDIS_URL=redis://localhost:6379/0

OBJECT_STORAGE_PROVIDER=local
OBJECT_STORAGE_BUCKET=enterprise-rag-local

ELASTICSEARCH_URL=http://localhost:9200
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=enterprise_chunks

EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-large

RERANKER_PROVIDER=bge
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1-mini
OPENAI_API_KEY=your-openai-api-key-here

# Query Routing & Multi-Source Retrieval
ENABLE_QUERY_ROUTING=false
ENABLE_WEB_SEARCH=false
ENABLE_KNOWLEDGE_GRAPH=false
TAVILY_API_KEY=
KG_PERSIST_PATH=./storage/kg
KG_AUTO_EXTRACT=false